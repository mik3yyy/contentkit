generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  name            String?
  image           String?
  password        String?
  hasPaid         Boolean    @default(false)
  paidAt          DateTime?
  stripePaymentId String?
  favorites       Favorite[]
  downloads       Download[]
  createdAt       DateTime   @default(now())
}

model Content {
  id            String     @id @default(cuid())
  title         String
  type          String
  niche         String
  r2Key         String     @unique
  thumbnailUrl  String?
  fileSizeBytes Int?
  durationSeconds Int?
  tags          String[]
  favorites     Favorite[]
  downloads     Download[]
  createdAt     DateTime   @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model Download {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  vid       String   // persistent visitor ID (localStorage UUID — unique browser)
  sid       String   // session ID (sessionStorage UUID — unique tab session)
  event     String   // page_view | pricing_view | cta_click | checkout_start | payment_success | signup_complete | signin
  page      String?  // URL pathname
  ref       String?  // document.referrer
  ua        String?  // user agent
  meta      String?  // JSON string for extra data (email after payment, etc.)
  createdAt DateTime @default(now())

  @@index([event])
  @@index([vid])
  @@index([createdAt])
}
