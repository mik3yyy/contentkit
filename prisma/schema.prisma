generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  name            String?
  image           String?
  password        String?
  hasPaid         Boolean    @default(false)
  paidAt          DateTime?
  stripePaymentId String?
  favorites       Favorite[]
  downloads       Download[]
  createdAt       DateTime   @default(now())
}

model Content {
  id            String     @id @default(cuid())
  title         String
  type          String
  niche         String
  r2Key         String
  thumbnailUrl  String?
  fileSizeBytes Int?
  favorites     Favorite[]
  downloads     Download[]
  createdAt     DateTime   @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model Download {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
